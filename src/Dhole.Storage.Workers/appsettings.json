  "Storage": {
    "ProviderName": "Local",
    "DefaultFolder": "files",
    "MaxFileSizeInBytes": 52428800,
    "ValidateFileSignature": false,
    "Local": {
      "RootPath": "storage/files",
      "CreateDirectoryIfNotExists": true,
      "UsePublicUrl": false
    },
    "AzureBlob": {
      "ConnectionString": "UseDevelopmentStorage=true",
      "ContainerName": "dhole-storage",
      "CreateContainerIfNotExists": true,
      "UsePublicUrl": false,
      "SignedUrlExpirationMinutes": 15
    },
    "S3": {
      "BucketName": "dhole-storage",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ServiceUrl": "",
      "ForcePathStyle": false,
      "UsePublicUrl": false,
      "SignedUrlExpirationMinutes": 15
    }
  },
  "Security": {
    "UploadRateLimit": {
      "MaxAttempts": 30,
      "WindowMinutes": 5,
      "BlockMinutes": 10
    }
  },
  "Messaging": {
    "Outbox": {
      "BatchSize": 50,
      "MaxRetryCount": 3,
      "PollingIntervalSeconds": 10,
      "BackgroundService": {
        "Enabled": true,
        "PollingIntervalSeconds": 10,
        "BatchSize": 50,
        "RunImmediately": true,
        "ErrorDelaySeconds": 5,
        "UseDistributedLock": false,
        "LockDurationSeconds": 60
      }
    },
    "Inbox": {
      "ProcessedMessageExpirationDays": 7,
      "Cleanup": {
        "Enabled": true,
        "OlderThanDays": 7,
        "BatchSize": 100,
        "PollingIntervalSeconds": 300,
        "RunImmediately": true
      }
    }
  },
  "Workers": {
    "Enabled": true,
    "MaxRetryCount": 3,
    "RetryDelaySeconds": 5,
    "UseDistributedLock": false,
    "LockDurationSeconds": 60,
    "StopOnUnhandledException": false,
    "Schedule": {
      "IntervalSeconds": 300,
      "RunImmediately": true
    }
  },
  "Seed": {
    "SuperAdmin": {
      "Email": "admin@dhole.com",
      "UserName": "admin",
