        "notifications.notification.requested": "dhole.notifications.events",
        "reports.report.requested": "dhole.reports.events"
      },
      "Publisher": {
        "MaxLength": 10000,
        "UseApproximateMaxLength": true
      },
      "Consumer": {
        "Enabled": true,
        "StreamName": "dhole.storage.events",
        "ConsumerGroup": "dhole-storage",
        "ConsumerName": "dhole-storage-worker",
        "BatchSize": 50,
        "PollingIntervalSeconds": 5,
        "ReadPendingMessages": true,
        "ErrorDelaySeconds": 10
      }
    }
  },
  "ConfigRedis": {
    "RevokedTokenPrefix": "auth:revoked_tokens:",
    "SessionPrefix": "auth:sessions:",
    "DefaultExpirationMinutes": 30
