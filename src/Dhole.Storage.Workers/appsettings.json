  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "dhole_storage:",
    "DefaultExpirationMinutes": 30,
    "LockExpirationSeconds": 60,
    "EnableHealthCheck": true,
    "Streams": {
      "Enabled": true,
      "DefaultStreamName": "dhole.storage.events",
      "SourceService": "DholeStorageService",
      "Destinations": {
