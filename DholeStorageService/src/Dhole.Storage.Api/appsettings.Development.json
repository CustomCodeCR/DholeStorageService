{
  "Auth": {
    "Jwt": {
      "RequireHttpsMetadata": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "ProviderName": "Local",
    "DefaultFolder": "files",
    "MaxFileSizeInBytes": 52428800,
    "ValidateFileSignature": false,
    "Local": {
      "RootPath": "storage/files",
      "CreateDirectoryIfNotExists": true,
      "UsePublicUrl": false
    },
    "AzureBlob": {
      "ConnectionString": "UseDevelopmentStorage=true",
      "ContainerName": "dhole-storage",
      "CreateContainerIfNotExists": true,
      "UsePublicUrl": false,
      "SignedUrlExpirationMinutes": 15
    },
    "S3": {
      "BucketName": "dhole-storage",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ServiceUrl": "",
      "ForcePathStyle": false,
      "UsePublicUrl": false,
      "SignedUrlExpirationMinutes": 15
    }
  }
}
